PORT=3000
BASE_URL=https://deine-domain.de

# WhatsApp / Meta Cloud API
WHATSAPP_VERIFY_TOKEN=dein_verify_token
WHATSAPP_TOKEN=dein_meta_system_user_token
WHATSAPP_PHONE_NUMBER_ID=deine_phone_number_id
ALLOWED_NUMBERS=

# OpenAI
OPENAI_API_KEY=dein_openai_api_key
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe

# Heizreport (heizreport.de)
HEIZREPORT_API_KEY=dein_heizreport_api_key
HEIZREPORT_API_BASE=https://api.heizreport.de
# Frei wählbares Geheimnis – identisch im Feld "Webhook Auth" in Heizreport eintragen
HEIZREPORT_WEBHOOK_AUTH=ein_langes_zufaelliges_geheimnis
# WhatsApp-Nummer (international, nur Ziffern), an die eingehende Heizreports als PDF gehen
HEIZREPORT_NOTIFY_NUMBER=

# WhatsApp-Nummer für neue Kundendienst-Anfragen von der Website
# (ohne Angabe wird HEIZREPORT_NOTIFY_NUMBER verwendet)
KUNDENDIENST_NOTIFY_NUMBER=

# WhatsApp-Nummer für neue Wärmepumpen-Anfragen vom Konfigurator
# (ohne Angabe wird KUNDENDIENST_/HEIZREPORT_NOTIFY_NUMBER verwendet)
WAERMEPUMPE_NOTIFY_NUMBER=

# Firma
COMPANY_NAME=G-Therm Haustechnik
COMPANY_ADDRESS=Lindener Str. 111 · 44879 Bochum
COMPANY_PHONE=0234 - 544 618 55
COMPANY_EMAIL=
COMPANY_OWNER=Musa Güldes
